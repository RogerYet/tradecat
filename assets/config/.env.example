OPINION_HOST=https://proxy.opinion.trade:8443
# Opinion 链节点（BSC）
OPINION_RPC_URL=https://bsc-dataseed.binance.org
# OPINION_API_KEY=

# ---------- NOFX (services/consumption/nofx-dev) ----------
