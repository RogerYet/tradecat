NOFX_DATA_API_BASE=http://nofxaios.com:30006
NOFX_DATA_API_AUTH=cm_568c67eae410d912c54c
NOFX_COIN_POOL_API_URL=
NOFX_OI_TOP_API_URL=
NOFX_QUANT_DATA_API_URL=
NOFX_OI_RANKING_API_URL=http://nofxaios.com:30006
NOFX_PUBLIC_IP_SERVICES=https://api.ipify.org?format=text,https://icanhazip.com,https://ifconfig.me
# 多交易所 API 基址
NOFX_BYBIT_BASE_URL=https://api.bybit.com
NOFX_BITGET_BASE_URL=https://api.bitget.com
NOFX_OKX_BASE_URL=https://www.okx.com
NOFX_LIGHTER_MAINNET_BASE_URL=https://mainnet.zklighter.elliot.ai
NOFX_LIGHTER_TESTNET_BASE_URL=https://testnet.zklighter.elliot.ai
NOFX_ASTER_BASE_URL=https://fapi.asterdex.com

# ---------- Google 翻译（可选）----------
# 用于自动翻译市场标题
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
GOOGLE_TRANSLATE_API_BASE=https://translate.google.com/translate_a/single
MYMEMORY_API_BASE=https://api.mymemory.translated.net/get

# ---------- 信号检测参数 ----------
# 大额交易检测
LARGE_TRADE_MIN_VALUE=5000
LARGE_TRADE_COOLDOWN=30000

# 新市场扫描
NEW_MARKET_SCAN_INTERVAL=60000
NEW_MARKET_LIMIT=500

# 聪明钱跟踪
SMART_MONEY_TRACK_TOP_N=100
SMART_MONEY_SCAN_INTERVAL=120000
SMART_MONEY_MIN_POSITION=500

# ---------- CSV 报告（polymarket /csv）----------
# 默认尽量走本地日志统计，API 排行需显式开启
CSV_ENABLE_API_RANKINGS=false
CSV_REPORT_TIMEOUT_MS=180000
CSV_FETCH_TIMEOUT_MS=15000
CSV_MARKET_MAX_ACTIVE=2000
CSV_MARKET_MAX_CLOSED=1000
CSV_INCLUDE_CLOSED=false
