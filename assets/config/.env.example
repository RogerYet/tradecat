NOFX_MARKET_API_BASE_URL_DEFAULT=http://127.0.0.1:8088/api/futures
NOFX_BINANCE_FAPI_BASE=https://fapi.binance.com
NOFX_BINANCE_TESTNET_BASE_URL=https://testnet.binancefuture.com
NOFX_POLYMARKET_GAMMA_API_BASE=https://gamma-api.polymarket.com
