# ============================================================
# TradeCat 配置模板
# ============================================================
# 
# 使用方法：
#   1. 复制此文件为 .env：cp .env.example .env
#   2. 修改 .env 中的配置值
#   3. 设置权限：chmod 600 .env
#   4. 重启服务生效
# 
# 注意：.env 包含敏感信息，已在 .gitignore 中排除
# 
# ============================================================

# ============================================================
# 网络代理
# ============================================================
# 用于访问 Binance API 和 Telegram API（国内需要代理）
# 格式：http://IP:端口 或 socks5://IP:端口
# 留空则不使用代理
HTTP_PROXY=
HTTPS_PROXY=

# predict-service 可选默认代理（当 HTTP_PROXY/HTTPS_PROXY 未设置时生效）
DEFAULT_PROXY_URL=
POLYMARKET_PROXY=
OPINION_PROXY=

# live monitor 可选 API 地址覆盖
POLYMARKET_CLOB_API_BASE=https://clob.polymarket.com
POLYMARKET_GAMMA_API_BASE=https://gamma-api.polymarket.com
POLYMARKET_DATA_API_BASE=https://data-api.polymarket.com
POLYMARKET_WEB_BASE=https://polymarket.com
KALSHI_API_BASE=https://api.elections.kalshi.com/trade-api/v2
KALSHI_WS_BASE=wss://api.elections.kalshi.com
KALSHI_WEB_BASE=https://kalshi.com
CLOB_API_BASE=https://clob.polymarket.com
GAMMA_API_BASE=https://gamma-api.polymarket.com
DATA_API_BASE=https://data-api.polymarket.com
OPINION_WEB_BASE=https://opinion.trade
TELEGRAM_API_BASE=https://api.telegram.org

# 数据库连接（推荐：LF + HF 双集群，避免同名表结构漂移导致写库崩溃）
#
# LF（低频/分时/K线与指标库）：TimescaleDB@5433，主要对象为 market_data.*
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/market_data

# data-service 专用库（LF，留空则复用 DATABASE_URL）
DATA_SERVICE_DATABASE_URL=postgresql://postgres:postgres@localhost:5433/market_data

# HF（高频/HFT 原子事实库）：TimescaleDB@15432，主要对象为 core.* / storage.* / crypto.raw_*
BINANCE_VISION_DATABASE_URL=postgresql://postgres:postgres@localhost:15432/market_data

# 单集群模式（可选）：
# - 若你只有一个 Timescale 实例：只设置 DATABASE_URL 即可；上面两个 *_DATABASE_URL 可留空。
# - DDL 初始化入口只允许跑 stacks：assets/database/db/stacks/{lf,hf}.sql（见 assets/database/db/README.md）
MARKET_DB_SCHEMA=market_data   # 兼容旧表/视图用
RAW_DB_SCHEMA=raw              # 1m K线、5m指标真实写入
QUALITY_DB_SCHEMA=quality      # 批次/血缘函数所在 schema

# ============================================================
# Query Service（api-service，consumption 唯一读出口）
# ============================================================
# consumption 层（telegram/sheets/vis 等）禁止直连 DB；统一通过 Query Service 读取。
#
# - QUERY_SERVICE_BASE_URL：Query Service 基地址（api-service 默认端口 8088）
# - QUERY_SERVICE_TOKEN：可选内部鉴权 token（Header: X-Internal-Token；留空=不启用鉴权）
# - QUERY_SERVICE_TIMEOUT_SECONDS：消费端请求超时（秒）
QUERY_SERVICE_BASE_URL=http://127.0.0.1:8088
QUERY_SERVICE_TOKEN=
QUERY_SERVICE_TIMEOUT_SECONDS=8

# Query Service 多数据源 DSN（可选；留空则回退 DATABASE_URL）
# - indicators：tg_cards.*（指标库）
# - market：market_data.*（行情库）
# - other：未来其它库
QUERY_PG_INDICATORS_URL=
QUERY_PG_MARKET_URL=
QUERY_PG_OTHER_URL=


# ============================================================
# Telegram Bot（必填）
# ============================================================
# 从 @BotFather 获取的 Bot Token
# 格式：数字:字母数字字符串（如 123456789:ABCdefGHI...）
# 获取方式：Telegram 搜索 @BotFather → /newbot → 按提示创建
BOT_TOKEN=

# 管理员用户ID（逗号分隔，可配置多个）
# 管理员可以访问配置面板、管理Bot设置
# 获取方式：Telegram 搜索 @userinfobot 获取你的用户ID
ADMIN_USER_IDS=

# 群聊白名单（逗号分隔，群ID通常为负数，如 -1001234567890）
# 为空时：仅响应私聊，群聊全部忽略
TELEGRAM_GROUP_WHITELIST=

# ============================================================
# Google Sheets 公共看板（sheets-service，可选）
# ============================================================
# 目标：将 TG 卡片同步到 Google Sheets（表格可公开只读，但写入必须鉴权）
#
# 推荐写入方式：Apps Script Webhook（Web App）
# - SHEETS_WEBHOOK_URL：形如 https://script.google.com/macros/s/.../exec
# - SHEETS_WEBHOOK_SECRET：HMAC 密钥（与 Apps Script 一致）
#
# 备选写入方式：Service Account + Sheets API（全 CLI，无需 Apps Script）
# - SHEETS_WRITE_MODE=sa
# - GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
# - SHEETS_SPREADSHEET_ID=...（可用 sheets-service --bootstrap 创建）
SHEETS_WRITE_MODE=webhook
SHEETS_WEBHOOK_URL=
SHEETS_WEBHOOK_SECRET=

# Webhook 请求参数（仅影响 sheets-service 客户端）
SHEETS_WEBHOOK_TIMEOUT_SECONDS=10
SHEETS_WEBHOOK_MAX_RETRIES=3
SHEETS_WEBHOOK_BACKOFF_BASE_SECONDS=1.0
SHEETS_WEBHOOK_BACKOFF_MAX_SECONDS=30.0

# SA（Service Account）模式参数（SHEETS_WRITE_MODE=sa）
SHEETS_SPREADSHEET_ID=
SHEETS_SA_CREDENTIALS_PATH=
SHEETS_SHARE_EMAIL=
SHEETS_PUBLIC_READ=0
SHEETS_DRIVE_FOLDER_ID=
# SA 写入重试（网络抖动/代理不稳定时建议增大）
# - 仅影响 SA 模式的 append/update 写入
# - 默认 2；弱网可设 3~5（注意配额与写入延迟）
SHEETS_SA_NET_WRITE_RETRIES=2
# dashboard 渲染固定列区间（默认从第一列开始，避免“整块卡片跑到 N 列以后”）
SHEETS_DASHBOARD_COL_L=A
# 多周期横向 + 全字段时列数会很大（例如超趋势：约 71 列），建议至少 BS
SHEETS_DASHBOARD_COL_R=BS
# 看板写入模式：
# - replace：按 card_type 固定槽位覆盖写（默认，不持续堆叠）
# - append：每次写入追加到末尾（审计流水视角）
SHEETS_DASHBOARD_MODE=replace

# replace 模式的槽位“最小预留高度”（行数）：
# 实际预留高度= max(最小预留高度, 该 card_type 当前渲染高度)，并记录在 meta.slot.<card_type>.h。
# 这样能避免“固定大高度”造成卡片之间巨大空洞，同时仍保留最小缓冲区。
SHEETS_DASHBOARD_SLOT_HEIGHT=10

# 事实表写入模式：
# - append：追加写入（审计台账；会持续增长，可能触发工作簿 1000 万 cells 上限）
# - none：只写看板（覆盖写），不再写 cards_index/EAV/rows/blobs
SHEETS_FACTS_MODE=append
SHEETS_BLOB_THRESHOLD_CHARS=20000

# 导出语言（默认 zh_CN）
SHEETS_EXPORT_LANG=zh_CN

# 多周期横向导出（0/1）：将“周期按钮”的 7 个周期合并成一张表（每行一个币种，多列多个周期）
SHEETS_EXPORT_MULTI_PERIODS=1

# 看板/币种查询：隐藏指定周期列（仅影响展示，不删除数据）
# - 逗号分隔：例如 "1m" 或 "1m,1w"
# - 禁用：0/off/none
SHEETS_HIDE_PERIODS=1m

# 固定列宽（可选，优先级最高）：用于你在表格 UI 手工拖拽调整好列宽后固化，避免后续刷新覆盖
# - 逗号/中文逗号分隔；长度不足会用最后一个值补齐，超出会截断
# - 示例（看板 v5，9 列）：SHEETS_DASHBOARD_FIXED_COL_WIDTHS=122，36，90，86，86，86，86，86，86
SHEETS_DASHBOARD_FIXED_COL_WIDTHS=
# - 示例（币种查询，9 列）：SHEETS_SYMBOL_QUERY_FIXED_COL_WIDTHS=90，148，87，78，78，78，78，78，78
SHEETS_SYMBOL_QUERY_FIXED_COL_WIDTHS=

# 顶部广告/赞助商栏（可选）：在看板顶部新增首行（A1），用于放置赞助商/返佣信息（默认不启用）
# - 优先读：SHEETS_DASHBOARD_BANNER_TEXT；为空则回退：SHEETS_TOP_BANNER_TEXT
SHEETS_DASHBOARD_BANNER_TEXT=
SHEETS_TOP_BANNER_TEXT=

# schema 模式：
# - full：包含事实表（cards_index/EAV/rows/blobs/meta），可用于审计与重建
# - minimal：只保留“看板 + 币种查询子表”（写入量最小，推荐公开只读看板）
SHEETS_SCHEMA_MODE=full

# 同步模式：
# - dashboard：写入“看板”展示面（SA 模式下可 reset+重绘，避免堆叠）
# - snapshot：只写本轮导出的卡片（不做看板 reset；更适合 webhook）
# - append：按事件 append-only（审计流水；工作簿 cells 容量会持续增长）
SHEETS_SYNC_MODE=snapshot

# 只导出指定卡片（逗号分隔 card_id）；留空=全部排行榜卡片
# 示例：SHEETS_EXPORT_CARDS=super_trend_ranking,macd_ranking,bb_ranking
SHEETS_EXPORT_CARDS=

# 是否包含 cards registry 黑名单卡片（0/1；默认 0）
SHEETS_EXPORT_INCLUDE_BLACKLIST=0

# 币种查询子表（tab）：
# - 会按币种生成子表（默认 4 个：BTC/ETH/BNB/SOL）
# - tab 名称默认：币种查询_<SYMBOL>
SHEETS_SYMBOL_TABS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT
SHEETS_SYMBOL_TAB_PREFIX=币种查询_
# - dashboard：仅在 dashboard 模式刷新（默认，写入量最小）
# - every：每轮都刷新
# - none：不刷新币种查询子表
SHEETS_SYMBOL_TABS_MODE=dashboard
# 刷新币种查询子表的最小间隔（秒）
SHEETS_SYMBOL_TABS_INTERVAL_SECONDS=900

# 币种查询子表的“raw 数值镜像区”：
# - hidden：写入 raw 数值列但默认隐藏（推荐；用于排序/图表/条件格式）
# - show：写入 raw 数值列并显示
# - off：关闭 raw 数值列（回退为 9 列显示区）
SHEETS_SYMBOL_QUERY_RAW_MODE=hidden

# prune-tabs 是否保留“看板变体 tab”（看板_方案*）：
# - 0：仅保留 看板 + 币种查询子表（默认）
# - 1：额外保留 3 套高密度看板变体（便于对比后选型）
SHEETS_PRUNE_KEEP_DASHBOARD_VARIANTS=0

# 使用服务器数据作为数据源（推荐）：直接让 `DATABASE_URL` 指向服务器的 PostgreSQL/TimescaleDB。
# - 若服务器不开放 5433：在本机用 ssh port-forward 建立隧道，再把 DATABASE_URL 指向本机端口即可。
# - 示例（本机转发到 15433）：
#     ssh -N -L 15433:127.0.0.1:5433 nvidia@<server> -i ~/.ssh/tradecat_nvidia
#     DATABASE_URL=postgresql://postgres:postgres@localhost:15433/market_data

# 生成看板“高密度变体”的选择器（可选，配合 --dashboard-variants）：
# - 留空：生成全部方案（1/2/3/4）
# - 示例：仅生成方案2和4：SHEETS_DASHBOARD_VARIANTS=2,4
SHEETS_DASHBOARD_VARIANTS=

# daemon 同步间隔（秒）
SHEETS_SYNC_INTERVAL_SECONDS=60

# 统一时钟刷新（0/1）：
# - 0：币种查询子表 / Polymarket 仍按各自 interval 节流（推荐，省配额）
# - 1：由 daemon tick 统一刷新：每轮把“币种查询子表 + Polymarket”也完整刷新一次（写入量更大）
SHEETS_UNIFIED_REFRESH=0

# 干跑模式：只写本地 outbox 不发网络（0/1）
SHEETS_SYNC_DRY_RUN=0

# 可选：自定义 outbox 路径（默认在 sheets-service/data/）
SHEETS_OUTBOX_PATH=
SHEETS_CHECKPOINT_PATH=

# ============================================================
# Polymarket（旁路子表，可选）
# ============================================================
# 1) Polymarket统计：解析 polymarket 服务 logs 并运行 node scripts/csv-report.js 输出分段 CSV
SHEETS_TAB_POLYMARKET_STATS=Polymarket统计
# 0=禁用；1=启用；auto=启用（失败也会写入错误卡片，避免用户“看不到 tab”）
SHEETS_POLYMARKET_STATS_ENABLE=auto
SHEETS_POLYMARKET_STATS_INTERVAL_SECONDS=900
# auto=优先 ssh；ssh=远端运行 node；local=本机运行 node
SHEETS_POLYMARKET_MODE=auto
# polymarket 服务目录（包含 scripts/csv-report.js）
SHEETS_POLYMARKET_SERVICE_DIR=
# 日志路径（相对 service_dir 或绝对路径；留空则优先 $HOME/.local/state/tradecat/polymarket.log）
SHEETS_POLYMARKET_LOG_FILE=
SHEETS_POLYMARKET_MAX_LOG_MB=200
SHEETS_POLYMARKET_TIMEOUT_SECONDS=30
SHEETS_POLYMARKET_TRANSLATE=0
SHEETS_POLYMARKET_ENABLE_API_RANKINGS=0
# ssh 参数（可选；留空则不走 ssh）
SHEETS_POLYMARKET_SSH_HOST=
SHEETS_POLYMARKET_SSH_USER=
SHEETS_POLYMARKET_SSH_KEY_PATH=
SHEETS_POLYMARKET_REMOTE_SERVICE_DIR=
SHEETS_POLYMARKET_REMOTE_LOG_FILE=
SHEETS_POLYMARKET_COMPACT_GRID=1
# 冻结（阅读体验）：默认冻结到 B 列（面板列 + 关键列），并冻结到首个分段表头（元信息/目录/表头不会滚走）
SHEETS_POLYMARKET_FROZEN_COLS=2
# 留空=自动（元信息+目录+首个分段表头）；也可显式指定整数（例如 3）
SHEETS_POLYMARKET_FROZEN_ROWS=
SHEETS_PRUNE_KEEP_POLYMARKET_STATS=1

# 2) Polymarket事件：读取 polymarket 结构化 facts（JSONL），展示最近 24h 可审计视图
SHEETS_TAB_POLYMARKET_EVENTS=Polymarket事件
SHEETS_POLYMARKET_FACTS_EVENTS_ENABLE=1
SHEETS_POLYMARKET_FACTS_EVENTS_INTERVAL_SECONDS=900
SHEETS_POLYMARKET_FACTS_MODE=auto
# facts 根目录（默认 $HOME/.local/state/tradecat/polymarket/facts）
SHEETS_POLYMARKET_FACTS_DIR=
SHEETS_POLYMARKET_FACTS_EVENTS_LIMIT=400
SHEETS_POLYMARKET_FACTS_MAX_MB=10
SHEETS_POLYMARKET_FACTS_TIMEOUT_SECONDS=20
SHEETS_PRUNE_KEEP_POLYMARKET_EVENTS=1

# ============================================================
# 国际化（i18n）
# ============================================================
# 默认语言（与 locales 目录一致），例：zh-CN / en
DEFAULT_LOCALE=en
# 支持的语言列表（逗号分隔，需有对应翻译文件）
SUPPORTED_LOCALES=zh-CN,en
# 回退语言（翻译缺失时使用）
FALLBACK_LOCALE=zh-CN

# ============================================================
# Binance API（可选）
# ============================================================
# 用于获取账户信息、下单等功能（order-service 需要）
# 仅采集公开市场数据时可留空
# 获取方式：https://www.binance.com/zh-CN/my/settings/api-management
# 注意：建议只开启读取权限，不要开启交易权限（除非使用 order-service）
BINANCE_API_KEY=
BINANCE_API_SECRET=

# order-service 交易网关地址（可按环境覆盖）
BINANCE_REST_BASE_MAINNET=https://fapi.binance.com
BINANCE_REST_BASE_TESTNET=https://testnet.binancefuture.com
BINANCE_WS_BASE_MAINNET=wss://fstream.binance.com
BINANCE_WS_BASE_TESTNET=wss://stream.binancefuture.com
BINANCE_WEB_BASE=https://www.binance.com
BINANCE_PING_URL=https://api.binance.com/api/v3/ping
SYMBOLS_ALL_URL=https://fapi.binance.com/fapi/v1/exchangeInfo

# Binance 上游地址（全局默认，可被各服务覆盖）
BINANCE_FAPI_BASE=https://fapi.binance.com
BINANCE_DATA_BASE=https://data.binance.vision
BINANCE_ALPHA_URL=https://www.binance.com/bapi/defi/v1/public/wallet-direct/buw/wallet/cex/alpha/all/token/list

# ============================================================
# 币种管理（核心配置）
# ============================================================
# 
# SYMBOLS_GROUPS 控制采集、计算、展示哪些币种
# 此配置同时作用于：data-service、trading-service、telegram-service
# 注：若设置了 DATA_SERVICE_DATABASE_URL，则 data-service 会优先使用它（避免两库混淆）
# 
    # 可选值：
    #   main4  - 默认主流 4 币（BTC/ETH/SOL/BNB）
    #   main6  - 使用 SYMBOLS_GROUP_main6 定义的 6 个主流币
    #   main20 - 使用 SYMBOLS_GROUP_main20 定义的 20 个主流币
    #   auto   - 自动选择高优先级币种（约 130-150 个）
    #   all    - 全部 USDT 永续合约（600+），资源消耗大
    #   亦可组合：defi,meme 等分组并行
    #
    SYMBOLS_GROUPS=main4

# ---------- 预定义分组 ----------
# 可自定义分组，格式：SYMBOLS_GROUP_分组名=币种1,币种2,...
# 币种必须是 Binance 永续合约交易对（以 USDT 结尾）
# 可在 https://www.binance.com/zh-CN/futures/trading-rules/perpetual 查看所有交易对

# 主流币 Top 4（默认）
SYMBOLS_GROUP_main4=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT

# 主流币 Top 6（BTC、ETH、BNB、SOL、XRP、DOGE）
SYMBOLS_GROUP_main6=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,DOGEUSDT

# 主流币 Top 20
SYMBOLS_GROUP_main20=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT,ADAUSDT,DOGEUSDT,AVAXUSDT,DOTUSDT,LINKUSDT,MATICUSDT,LTCUSDT,UNIUSDT,ATOMUSDT,ETCUSDT,XLMUSDT,APTUSDT,NEARUSDT,FILUSDT,ARBUSDT

# DeFi 板块（去中心化金融）
SYMBOLS_GROUP_defi=AAVEUSDT,UNIUSDT,MKRUSDT,COMPUSDT,SNXUSDT,CRVUSDT,LDOUSDT,PENDLEUSDT

# Meme 板块（模因币）
SYMBOLS_GROUP_meme=DOGEUSDT,SHIBUSDT,PEPEUSDT,FLOKIUSDT,BONKUSDT,WIFUSDT,BOMEUSDT

# AI 板块（人工智能相关）
SYMBOLS_GROUP_ai=FETUSDT,AGIXUSDT,OCEANUSDT,RENDERUSDT,TAOUSDT,ARKMUSDT

# Layer2 板块（以太坊二层扩展）
SYMBOLS_GROUP_layer2=ARBUSDT,OPUSDT,MATICUSDT,STXUSDT,IMXUSDT,METISUSDT

# ---------- 额外添加/排除 ----------
# 在分组基础上额外添加币种（逗号分隔）
# 示例：SYMBOLS_EXTRA=NEWUSDT,HOTUSDT
SYMBOLS_EXTRA=

# 强制排除的币种（逗号分隔，优先级最高，会从任何分组中移除）
# 示例：SYMBOLS_EXCLUDE=LUNAUSDT,USTCUSDT
SYMBOLS_EXCLUDE=

# ============================================================
# 周期配置
# ============================================================
# K线周期（逗号分隔）
# 可选：1m, 3m, 5m, 15m, 30m, 1h, 2h, 4h, 6h, 8h, 12h, 1d, 3d, 1w, 1M
# 周期越多，数据量和计算量越大
INTERVALS=1m,5m,15m,1h,4h,1d,1w

# K线采集周期（data-service WebSocket 订阅使用）
KLINE_INTERVALS=1m,5m,15m,1h,4h,1d,1w

# 期货指标周期（data-service REST API 采集使用）
# 注意：Binance 期货指标最小粒度为 5m，无 1m 数据
FUTURES_INTERVALS=5m,15m,1h,4h,1d,1w

# ============================================================
# 数据保留策略
# ============================================================
# 每个币种每个周期在 SQLite 中保留的记录条数
# 超出后自动清理旧数据，控制数据库大小
# 
# 计算公式：保留时长 = 条数 × 周期
# 例：RETENTION_1m=120 表示保留 120 分钟 = 2 小时
#     RETENTION_1d=120 表示保留 120 天 = 4 个月
#
RETENTION_1m=120
RETENTION_5m=120
RETENTION_15m=96
RETENTION_1h=144
RETENTION_4h=84
RETENTION_1d=120
RETENTION_1w=48

# ============================================================
# data-service 配置（数据采集服务）
# ============================================================
# 
# 回填模式（首次启动或数据缺失时使用）：
#   all  - 全量回填（默认，按起始日或 10 年上限）
#   days - 按天数回填（使用 BACKFILL_DAYS）
#   none - 禁用回填
#   full 兼容映射为 all
BACKFILL_MODE=all

# 回填起始日期（可选，BACKFILL_MODE=all 时优先使用）
# 留空则默认回溯约 10 年
# 示例：BACKFILL_START_DATE=2018-01-01
BACKFILL_START_DATE=

# 回填天数（BACKFILL_MODE=days 时生效）
# 建议值：7-30 天
BACKFILL_DAYS=30

# 启动时是否先跑一次全量补齐（true/false）
BACKFILL_ON_START=false

# 最大并发请求数（控制对 Binance API 的并发访问）
# 建议值：3-10，过高可能触发限流
MAX_CONCURRENT=5

# 每分钟最大请求数（Binance 限制约 1200/分钟）
# 建议留 30% 余量，设为 800-1000
RATE_LIMIT_PER_MINUTE=1800

# WebSocket 断线重连检查间隔（秒）
# 检测 WebSocket 连接是否正常，断线后自动重连
BINANCE_WS_GAP_INTERVAL=600

# WebSocket 数据源
#   binance_ws   - 官方 WebSocket（推荐，延迟低）
#   cryptofeed   - cryptofeed 库（备用，兼容性好）
BINANCE_WS_SOURCE=binance_ws

# 守护自愈（按 DB 新鲜度重启 ws）
# 触发条件：TimescaleDB 的 candles_1m 最新 bucket_ts 距离当前时间超过阈值，且连续 N 次满足
# 注意：用于“ws 进程活着但不再写入”的自愈场景；DB 查询失败时不会强制重启（避免抖动导致重启风暴）
DATA_SERVICE_WS_DB_SELF_HEAL_ENABLED=1
DATA_SERVICE_WS_DB_STALE_MAX_AGE_SECONDS=240
DATA_SERVICE_WS_DB_STALE_CONSECUTIVE=3
DATA_SERVICE_WS_DB_SELF_HEAL_WARMUP_SECONDS=300
DATA_SERVICE_WS_DB_CHECK_CONNECT_TIMEOUT_SECONDS=3
# ban 冷却期间是否跳过 ws DB 自愈重启（避免 ban 期间重启风暴）
DATA_SERVICE_WS_DB_SELF_HEAL_SKIP_ON_BAN=1

# REST 缺口补齐并发（K线 REST 补齐）；过高容易触发 429/418（IP ban）
DATA_SERVICE_REST_BACKFILL_WORKERS=2

# data-service 上游地址覆盖（留空则回退到 BINANCE_* 全局配置）
DATA_SERVICE_BINANCE_FAPI_BASE=
DATA_SERVICE_BINANCE_DATA_BASE=
DATA_SERVICE_BINANCE_ALPHA_URL=

# datacat-service 上游地址（可替换为网关/镜像）
DATACAT_BINANCE_FAPI_BASE=https://fapi.binance.com
DATACAT_BINANCE_DATA_BASE=https://data.binance.vision
DATACAT_BINANCE_ALPHA_URL=https://www.binance.com/bapi/defi/v1/public/wallet-direct/buw/wallet/cex/alpha/all/token/list

# ============================================================
# trading-service 配置（指标计算服务）
# ============================================================
# 
# 指标结果固定写入 PostgreSQL（tg_cards.*），不再写入 SQLite（market_data.db）。
# PG 指标 schema（表结构由 assets/database/db/schema/021_tg_cards_sqlite_parity.sql 定义）
INDICATOR_PG_SCHEMA=tg_cards

# 计算线程/进程数
# 建议值：CPU 核心数，过高会导致资源竞争
MAX_WORKERS=4

# 计算后端：
#   thread  - 线程池（推荐，适合 IO 密集型，内存占用低）
#   process - 进程池（适合 CPU 密集型，但内存占用高）
#   hybrid  - 混合模式（小任务用线程，大任务用进程）
COMPUTE_BACKEND=thread

# auto 模式下的高优先级币种数量上限
# 影响 SYMBOLS_GROUPS=auto 时选择的币种数量
HIGH_PRIORITY_TOP_N=50

# ---------- 指标开关 ----------
# 只启用指定指标（逗号分隔，留空=全部启用）
# 可用于调试或减少计算量
# 示例：INDICATORS_ENABLED=macd,rsi,布林带
INDICATORS_ENABLED=

# 禁用指定指标（逗号分隔）
# 示例：INDICATORS_DISABLED=k线形态,支撑阻力
INDICATORS_DISABLED=

# ============================================================
# telegram-service 配置（Telegram Bot 服务）
# ============================================================
# 
# 是否禁用 Binance API 调用（1=禁用，0=启用）
# 禁用后：不获取实时价格，使用 PG 指标库缓存数据（tg_cards.*）
# 启用后：可获取实时价格，但需要配置代理
#
BINANCE_API_DISABLED=1

# ---------- 单币快照功能 ----------
# 用户发送 "BTC!" 触发单币详情查询
# 0=启用, 1=禁用（性能优化时可临时关闭）
#
DISABLE_SINGLE_TOKEN_QUERY=0

# 单币快照屏蔽字段（逗号分隔）
# 这些字段不会在单币查询表格中显示
# 示例：SNAPSHOT_HIDDEN_FIELDS=最近翻转时间,某字段
#
SNAPSHOT_HIDDEN_FIELDS=最近翻转时间

# ---------- 卡片开关 ----------
# 只启用指定卡片（逗号分隔，留空=全部启用）
# 示例：CARDS_ENABLED=资金流向,MACD,RSI
CARDS_ENABLED=

# 禁用指定卡片（逗号分隔）
# 示例：CARDS_DISABLED=K线形态,支撑阻力
CARDS_DISABLED=

# ---------- 屏蔽币种（黑名单）----------
# 这些币种不会出现在排行榜中（逗号分隔）
# 用于屏蔽已下架、异常或不想显示的币种
# 与 SYMBOLS_EXCLUDE 不同：BLOCKED_SYMBOLS 只影响展示，不影响采集和计算
BLOCKED_SYMBOLS=BNXUSDT,ALPACAUSDT

# ============================================================
# signal-service / sheets-service 状态库（PG）
# ============================================================
# 状态库固定写入 PG，不再使用本地 .db：
# - signal_state.*：执行 assets/database/db/schema/022_signal_state.sql
# - sheets_state.*：执行 assets/database/db/schema/023_sheets_state.sql

# ============================================================
# ai-service 配置（AI 数据服务）
# ============================================================
# 
# 控制 AI 服务从 PG(tg_cards) 获取哪些指标表
# 减少表数量可显著降低 payload 大小，提升 LLM 处理效率
#

# ---------- 指标表选择 ----------
# 启用的指标表（逗号分隔，留空=全部 38 张表）
# 
AI_INDICATOR_TABLES=

# 禁用的指标表（逗号分隔，优先级高于 AI_INDICATOR_TABLES）
# 示例：AI_INDICATOR_TABLES_DISABLED=数据监控.py,期货情绪缺口监控.py
AI_INDICATOR_TABLES_DISABLED=

# ---------- LLM 调用方式 ----------
# cli: 本地 Gemini CLI（默认）
# api: 走内部 LLM API 网关
# openai_compat: 直连 OpenAI 兼容接口（只需 API Key）
LLM_BACKEND=cli

# OpenAI 兼容接口地址（示例: https://api.openai.com/v1）
LLM_API_BASE_URL=

# OpenAI 兼容接口密钥
EXTERNAL_API_KEY=

# 模型名称（openai_compat 时必填，例如 gpt-4o-mini）
LLM_MODEL=

# 最大输出 token（仅 API / openai_compat 生效）
LLM_MAX_TOKENS=32000

# 超大 payload 保护（字符数阈值）
AI_LARGE_PAYLOAD_CHAR_LIMIT=200000
# 超出阈值时强制 Gemini CLI（1=强制，0=返回错误）
AI_FORCE_GEMINI_ON_LARGE_PAYLOAD=1

# 默认提示词（CLI 或未显式指定时使用）
AI_DEFAULT_PROMPT=市场全局解析

# 运行记录开关（1=启用, 0=关闭）
AI_RECORD_ENABLED=1
# 记录内容细分开关
AI_RECORD_PAYLOAD=1
AI_RECORD_PROMPT=1
AI_RECORD_MESSAGES=1
AI_RECORD_ANALYSIS=1
# 保留最近 N 次记录（0=不限制）
AI_RECORD_MAX_DIRS=0

# ============================================================
# order-service 配置（交易执行服务）
# ============================================================
# 使用此服务需要配置 BINANCE_API_KEY 和 BINANCE_API_SECRET
# 并确保 API Key 有交易权限
# 
# 警告：交易有风险，请在测试网充分测试后再使用真实资金
# Binance 测试网：https://testnet.binancefuture.com
#
# （暂无其他配置项）

# ============================================================
# markets-service 配置（全市场数据采集服务）
# ============================================================
# 独立数据库连接（留空则复用全局 DATABASE_URL）
# 说明：
# - 若你采用 LF+HF 双集群：请按需要显式指定（LF=5433，HF=15432），避免误连写错库
# - 若你是单集群模式：可留空复用 DATABASE_URL
MARKETS_SERVICE_DATABASE_URL=
# 默认代理（仅在 HTTP_PROXY/HTTPS_PROXY 未设置时生效）
MARKETS_SERVICE_DEFAULT_PROXY=
# 上游地址覆盖（留空则回退到 BINANCE_* 全局配置）
MARKETS_SERVICE_BINANCE_FAPI_BASE=
MARKETS_SERVICE_BINANCE_DATA_BASE=

# 加密货币写入模式:
#   raw    - 写入 raw.crypto_kline_1m (新架构，含血缘追踪)
#   legacy - 写入 market_data.candles_1m (兼容 trading-service)
CRYPTO_WRITE_MODE=raw

# ---------- 订单簿双层采样配置 (行业最佳实践) ----------
# L1 Tick 层: 高频采样，捕获价差/失衡信号
# L2 Full 层: 低频采样，保存完整盘口

# L1 tick 采样间隔（秒），默认 1
# 建议: 1-2s，捕获 95%+ 价差变化
ORDER_BOOK_TICK_INTERVAL=1

# L2 full 采样间隔（秒），默认 5
# 建议: 5-10s，平衡存储与精度
ORDER_BOOK_FULL_INTERVAL=5

# 每侧档位数，默认 1000（全量）
ORDER_BOOK_DEPTH=1000

# 数据保留天数
# tick 层自动保留 7 天，full 层保留此配置天数
ORDER_BOOK_RETENTION_DAYS=30

# 指定币种（可选，逗号分隔，不设则用 SYMBOLS_GROUPS）
# ORDER_BOOK_SYMBOLS=BTCUSDT,ETHUSDT

# ============================================================
# 信号服务（signal-service）
# ============================================================
# 信号数据新鲜度阈值（秒），超过则不生成信号；默认 600
SIGNAL_DATA_MAX_AGE=600

# PG 信号全局冷却时间（秒），防止重复推送；默认 300
# 与规则级冷却配合使用，持久化到 signal_state.cooldown
COOLDOWN_SECONDS=300

# ============================================================
# api-service 配置（REST API 服务，可选）
# ============================================================
# 监听端口（默认 8088）
API_SERVICE_PORT=8088

# ============================================================
# vis-service 配置（可视化渲染服务）
# ============================================================
# 监听地址与端口
VIS_SERVICE_HOST=0.0.0.0
VIS_SERVICE_PORT=8087

# 访问令牌（可选，若设置则所有请求需携带头 X-Vis-Token）
VIS_SERVICE_TOKEN=

# 数据源（留空默认复用全局 DATABASE_URL）
VIS_SERVICE_DATABASE_URL=

# 渲染缓存（秒）与容量
VIS_SERVICE_CACHE_TTL_SECONDS=300
VIS_SERVICE_CACHE_MAX_ITEMS=128

# ============================================================
# fate-service 配置（八字排盘服务）
# ============================================================
# 
# fate-service 使用独立的 Bot Token
#

# fate-service Bot Token（必填，从 @BotFather 获取）
FATE_BOT_TOKEN=

# fate-service 管理员 ID（逗号分隔）
FATE_ADMIN_USER_IDS=

# fate-service API 服务端口（FastAPI）
FATE_SERVICE_HOST=0.0.0.0
FATE_SERVICE_PORT=8001

# ============================================================
# predict-service 配置（预测市场信号服务）
# ============================================================
# 
# predict-service 使用全局 BOT_TOKEN 和 ADMIN_USER_IDS
# 包含 polymarket / kalshi / opinion 三个子服务
#

# ---------- Polymarket ----------
# WebSocket 配置（通常不需要修改）
POLYMARKET_WS_HOST=wss://ws-live-data.polymarket.com
# Node.js 安装脚本地址（deploy 脚本使用）
NODEJS_SETUP_URL=https://deb.nodesource.com/setup_18.x
# 代理 URL 协议（用于脚本展示）
PROXY_URL_SCHEME=http

# ---------- Kalshi ----------
# Kalshi API 凭证（可选，用于获取用户数据）
# KALSHI_API_KEY_ID=
# KALSHI_PRIVATE_KEY_PATH=

# ---------- Opinion ----------
