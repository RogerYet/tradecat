    {
      "id": "seq_step1",
      "type": "text",
      "text": "**1. Start Trader**\n`POST /api/traders/:id/start`",
      "x": -300,
      "y": 980,
      "width": 200,
      "height": 60,
      "color": "6"
    },
    {
      "id": "seq_step2",
      "type": "text",
      "text": "**2. StartTrader(id)**",
      "x": 100,
      "y": 980,
      "width": 160,
      "height": 50,
      "color": "6"
    },
    {
      "id": "seq_step3",
      "type": "text",
      "text": "**3. trader.Run()**\n启动主循环",
      "x": 280,
      "y": 980,
      "width": 160,
      "height": 60,
      "color": "3"
    },
    {
      "id": "seq_step4",
      "type": "text",
      "text": "**4. 定时触发**\n`ScanInterval`",
      "x": 480,
      "y": 1080,
      "width": 140,
      "height": 60,
      "color": "1"
    },
    {
      "id": "seq_step5",
      "type": "text",
      "text": "**5. GetCandidateCoins()**\n获取候选币种",
      "x": 480,
      "y": 1180,
      "width": 180,
      "height": 60,
      "color": "1"
    },
    {
      "id": "seq_step6",
      "type": "text",
      "text": "**6. FetchMarketData()**\n获取 K线/指标",
      "x": 480,
      "y": 1280,
      "width": 180,
      "height": 60,
      "color": "1"
    },
    {
      "id": "seq_step7",
      "type": "text",
      "text": "**7. GetFullDecision(ctx)**\n构建 Context",
      "x": 700,
      "y": 1180,
      "width": 180,
      "height": 60,
      "color": "1"
    },
    {
      "id": "seq_step8",
      "type": "text",
      "text": "**8. BuildPrompt()**\nSystem + User Prompt",
      "x": 700,
      "y": 1280,
      "width": 180,
      "height": 60,
      "color": "1"
    },
    {
      "id": "seq_step9",
      "type": "text",
      "text": "**9. CallWithMessages()**\n调用 AI API",
      "x": 900,
      "y": 1280,
      "width": 180,
      "height": 60,
      "color": "4"
    },
    {
      "id": "seq_step10",
      "type": "text",
      "text": "**10. AI Response**\n返回 JSON 决策",
      "x": 900,
      "y": 1380,
      "width": 180,
      "height": 60,
      "color": "4"
    },
    {
      "id": "seq_step11",
      "type": "text",
      "text": "**11. ParseDecision()**\n解析决策结果",
      "x": 700,
      "y": 1380,
      "width": 180,
      "height": 60,
      "color": "1"
    },
    {
      "id": "seq_step12",
      "type": "text",
      "text": "**12. ExecuteDecision()**\n执行交易决策",
      "x": 480,
      "y": 1480,
      "width": 180,
      "height": 60,
      "color": "1"
    },
    {
      "id": "seq_step13",
      "type": "text",
      "text": "**13. OpenLong/Short()**\n下单到交易所",
      "x": 1100,
      "y": 1480,
      "width": 180,
      "height": 60,
      "color": "4"
    },
    {
      "id": "seq_step14",
      "type": "text",
      "text": "**14. Order Result**\n返回订单结果",
      "x": 1100,
      "y": 1580,
      "width": 180,
      "height": 60,
      "color": "4"
    },
    {
      "id": "seq_step15",
      "type": "text",
      "text": "**15. SaveDecision()**\n保存决策记录到 DB",
      "x": 480,
      "y": 1580,
      "width": 200,
      "height": 60,
      "color": "5"
    },
    {
      "id": "seq_step16",
      "type": "text",
      "text": "**16. Loop**\n等待下一个 ScanInterval",
      "x": 480,
      "y": 1680,
      "width": 200,
